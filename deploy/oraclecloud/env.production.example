DEVELOPMENT_MODE=false
DASHBOARD_API_KEY=replace-with-strong-random-token
TRUST_PROXY_COUNT=1
DASHBOARD_CORS_ORIGINS=https://your-domain.example
SESSION_TOKEN_TTL=3600

# Keep localhost if Postgres runs on the same Oracle VM.
DATABASE_URL=postgresql://postgres:replace-password@localhost:5432/trading_bot

# External Redis example. Replace with your own if used.
REDIS_URL=redis://default:replace-password@your-redis-host:6379
REDIS_CACHE_PREFIX=trading_bot:cache:
REDIS_MAX_CONNECTIONS=10

# Core market-data configuration.
DERIV_ENABLED=true
DERIV_APP_ID=replace-with-deriv-app-id
DERIV_TOKEN=replace-with-deriv-token
IG_ENABLED=true
IG_ENVIRONMENT=demo
IG_API_KEY=replace-with-ig-api-key
IG_IDENTIFIER=replace-with-ig-identifier
IG_PASSWORD=replace-with-ig-password
IG_ACCOUNT_ID=
IG_EPIC_MAP={"XAU/USD":"CS.D.IN_GOLD.MFI.IP","XAG/USD":"CS.D.IN_SILVER.MFI.IP","WTI":"CC.D.CL.BMU.IP"}
IG_ROUTED_CATEGORIES=commodities
IG_ROUTED_ASSETS=GER40,AUS200,JPN225
IG_ROUTE_TO_DERIV_BY_DEFAULT=false
IG_MAX_ROUTED_ASSETS=6
IG_STREAMING_HOLDOFF_SEC=300
BINANCE_PUBLIC_DATA_ENABLED=true
DUKASCOPY_HISTORY_ENABLED=true
DUKASCOPY_SYMBOL_MAP=
FMP_HISTORY_ENABLED=true
FMP_API_KEY=replace-with-fmp-api-key
FMP_SYMBOL_MAP=
DERIV_SYMBOL_MAP={"EUR/USD":"frxEURUSD","EUR/JPY":"frxEURJPY","EUR/GBP":"frxEURGBP","GBP/JPY":"frxGBPJPY","GBP/USD":"frxGBPUSD","AUD/USD":"frxAUDUSD","NZD/USD":"frxNZDUSD","USD/JPY":"frxUSDJPY","USD/CAD":"frxUSDCAD","USD/CHF":"frxUSDCHF","BTC-USD":"cryBTCUSD","ETH-USD":"cryETHUSD","XAU/USD":"frxXAUUSD","XAG/USD":"frxXAGUSD","US30":"OTC_DJI","US100":"OTC_NDX","US500":"OTC_SPC","UK100":"OTC_FTSE","GER40":"OTC_GDAXI","AUS200":"OTC_AS51","JPN225":"OTC_N225"}

# Required if you use AI summaries / narrative features.
OPENAI_API_KEY=replace-with-openai-api-key

# Telegram command bot.
COMMAND_BOT_TOKEN=replace-with-command-bot-token
COMMAND_BOT_CHAT_ID=replace-with-command-chat-id

# Standalone DeepSeek chat bot.
DEEPSEEK_TELEGRAM_TOKEN=replace-with-deepseek-bot-token
DEEPSEEK_TELEGRAM_CHAT_ID=

# Telegram intelligence / whale bot.
WHALE_TELEGRAM_TOKEN=replace-with-whale-bot-token
INTELLIGENCE_CHAT_ID=replace-with-intelligence-chat-id
TELEGRAM_API_ID=replace-with-telegram-api-id
TELEGRAM_API_HASH=replace-with-telegram-api-hash
TELEGRAM_PHONE=replace-with-telegram-phone
TELEGRAM_SESSION=whale_session
WHALE_TELEGRAM_CHANNELS=whalebotalerts
WHALE_ALLOWED_ASSETS=BTC-USD,ETH-USD,BNB-USD,SOL-USD,XRP-USD
WHALE_TWITTER_WHALE_ENABLED=false
WHALE_REDDIT_WHALE_ENABLED=false

# Optional but used by current runtime integrations.
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
WHALE_ALERT_KEY=

# Optional but recommended for cleaner Reddit behavior.
REDDIT_MAX_CONCURRENT_REQUESTS=1
REDDIT_MIN_REQUEST_INTERVAL_SECONDS=12
REDDIT_GLOBAL_429_BACKOFF_SECONDS=300
REDDIT_SUBREDDIT_429_BACKOFF_SECONDS=900
REDDIT_MAX_BACKOFF_SECONDS=3600
REDDIT_USER_AGENT=forex_prediction_bot/1.0 (Oracle Cloud production)

# Calendar fallback configuration.
ECON_CALENDAR_FOREX_FACTORY_ENABLED=true
ECON_CALENDAR_ALLOW_TRADING_ECONOMICS_GUEST=false
ECON_CALENDAR_HTTP_TIMEOUT=15

# Chain RPC defaults. Replace only if you use your own providers.
BNB_RPC_URL=https://bsc-dataseed1.binance.org
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
XRPL_RPC_URL=https://s1.ripple.com:51234

# Background automation defaults.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
MAX_SCAN_WORKERS=4
MAX_TRAINING_WORKERS=2
AUTO_RESEARCH_MAX_PARALLEL_ASSETS=1
ML_SERVICE_PORT=9100
LOG_LEVEL=INFO

# Paper runtime can use provisional research for non-commodities only.
GOVERNANCE_REQUIRE_MODEL_RESEARCH=true
GOVERNANCE_ALLOW_PROVISIONAL_MODEL_RESEARCH_IN_PAPER=true
