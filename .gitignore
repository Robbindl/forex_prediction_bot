    health_log.txt

    # WEB APP
    # ------------------------------------------------
    static/
    *.pid
    *.sock

    # IDE
    # ------------------------------------------------
    .vscode/
    .idea/
    *.swp
    *.swo
    *~
    .DS_Store
    Thumbs.db
    desktop.ini

    # PACKAGES
