# ==================================================
    # ULTIMATE .GITIGNORE FOR TRADING BOT
    # ==================================================

    # SECURITY - NEVER COMMIT THESE!
    # ------------------------------------------------
    .env
    .env.*
    !.env.example
    config/*_config.json
    config/telegram_config.json
    config/email_config.json
    *key*.py
    *secret*.py

    # PYTHON
    # ------------------------------------------------
    __pycache__/
    *.py[cod]
    *.pyc
    *.pyo
    *.pyd
    .Python
    .pytest_cache/
    .coverage
    htmlcov/
    *.cover
    *.log
    *.log.*

    # VIRTUAL ENVIRONMENTS
    # ------------------------------------------------
    venv/
    venv311/
    env/
    ENV/
    pythonenv*

    # TRADING DATA
