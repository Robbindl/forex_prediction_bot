# ==================================================
# COMPLETE TRADING BOT ENVIRONMENT VARIABLES
# ==================================================
# This is a TEMPLATE file - copy to .env and add your real keys
# Created for: Ultimate Trading Bot
# Python: 3.11+
# ==================================================

# ==================================================
# MARKET DATA APIS
# ==================================================

# Alpha Vantage (https://www.alphavantage.co)
# Free tier: 5 calls/minute
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Finnhub (https://finnhub.io)
# Free tier: 60 calls/minute
FINNHUB_KEY=your_finnhub_key_here

# Twelve Data (https://twelvedata.com)
# Free tier: 800 calls/day, 8 calls/minute
TWELVEDATA_KEY=your_twelve_data_key_here

# iTick API (https://itick.org)
# Best for: Forex, Stocks, Crypto - faster than Finnhub
ITICK_TOKEN=your_itick_token_here

# OilPriceAPI (https://www.oilpriceapi.com)
# Best for: Commodities (Gold, Silver, Oil)
# Free tier: 7-day trial with 10,000 requests
OILPRICE_API_KEY=your_oilprice_api_key_here

# ==================================================
# NEWS APIS
# ==================================================

# NewsAPI (https://newsapi.org)
# Free tier: 100 requests/day
NEWSAPI_KEY=your_newsapi_key_here

# GNews (https://gnews.io)
# Free tier: 100 requests/day
GNEWS_KEY=your_gnews_key_here

# RapidAPI (https://rapidapi.com)
# Used for multiple news sources
RAPIDAPI_KEY=your_rapidapi_key_here

# Whale Alert (https://whale-alert.io)
# Tracks large crypto transactions
WHALE_ALERT_KEY=your_whale_alert_key_here

# ==================================================
# TWITTER API (for Kobeissi Letter, Walter Bloomberg)
# ==================================================
# Get from: https://developer.twitter.com/en/portal/dashboard
# Free tier: 500k tweets/month

# Bearer Token (for app-only authentication)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Consumer Keys (API Keys)
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here

# Access Tokens (for user authentication)
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# ==================================================
# APIFY (Optional - for Forbes Scraper)
# ==================================================
# Get from: https://apify.com/
APIFY_TOKEN=your_apify_token_here

# ==================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==================================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/trading_bot

# Individual database settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_bot
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ==================================================
# TELEGRAM ALERTS
# ==================================================
# Get bot token from @BotFather on Telegram
# Get chat ID by messaging @userinfobot

TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==================================================
# EMAIL ALERTS (Gmail App Password)
# ==================================================
# How to get App Password:
# 1. Enable 2-Factor Authentication on Google Account
# 2. Go to Security → App Passwords
# 3. Generate password for "Mail"

EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# ==================================================
# TRADING DEFAULTS
# ==================================================

# Default account balance for paper trading
DEFAULT_BALANCE=30

# Default risk per trade (percentage)
DEFAULT_RISK=1.0

# Maximum concurrent positions
MAX_POSITIONS=5

# ==================================================
# ADVANCED SETTINGS (Optional)
# ==================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Cache TTL in seconds
CACHE_TTL=30

# WebSocket reconnection settings
WS_RECONNECT_DELAY=30
WS_MAX_RECONNECT_DELAY=120