# ==================================================
# TRADING BOT — ENVIRONMENT VARIABLES TEMPLATE
# ==================================================
# Copy this file to .env and fill in REAL values.
# Keys marked [REQUIRED] will cause errors if missing.
# Keys marked [OPTIONAL] degrade gracefully if absent.
# Keys marked [CRYPTO_ONLY] only affect crypto trading.
# ==================================================

# ==================================================
# MARKET DATA APIs
# ==================================================

# Alpha Vantage [OPTIONAL]
ALPHA_VANTAGE_KEY=

# Finnhub [OPTIONAL — used for real-time quotes]
FINNHUB_KEY=

# Twelve Data [OPTIONAL — best for forex/crypto OHLCV]
TWELVEDATA_KEY=

# iTick [OPTIONAL]
ITICK_TOKEN=

# OilPrice API [OPTIONAL — commodities]
OILPRICE_API_KEY=

# ==================================================
# NEWS APIs
# ==================================================

# NewsAPI [REQUIRED for news sentiment]
NEWSAPI_KEY=

# GNews [REQUIRED for news sentiment]
GNEWS_KEY=

# RapidAPI [REQUIRED for some news sources]
RAPIDAPI_KEY=

# MarketAux [OPTIONAL]
MARKETAUX_TOKEN=

# Apify [OPTIONAL — used for Twitter scraping if no Twitter API key]
APIFY_TOKEN=

# FRED — Federal Reserve Economic Data [OPTIONAL — macro data]
FRED_API_KEY=

# Financial Modeling Prep [REQUIRED for put/call ratio on US indices]
# Get free key at https://financialmodelingprep.com/
FMP_API_KEY=

# ==================================================
# WHALE ALERT API [CRYPTO_ONLY]
# ==================================================
# Get key at https://whale-alert.io/
# Without this, only Twitter/Telegram whale sources are used.
# IMPORTANT: Never leave this as a placeholder — the bot will warn loudly.
WHALE_ALERT_KEY=

# ==================================================
# TWITTER / X API [OPTIONAL — crypto sentiment]
# ==================================================
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ==================================================
# REDDIT API [OPTIONAL — crypto sentiment only]
# ==================================================
# Create an app at https://www.reddit.com/prefs/apps (script type)
# Without these, Reddit sentiment is disabled. No silent failures.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trading-bot/1.0

# ==================================================
# TELEGRAM — COMMAND BOT [REQUIRED for alerts]
# ==================================================
# Get token from @BotFather, chat ID from @userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Separate channel for intelligence alerts (Phase 7)
# Defaults to TELEGRAM_CHAT_ID if not set
INTELLIGENCE_CHAT_ID=

# ==================================================
# TELEGRAM — WHALE BOT [OPTIONAL]
# ==================================================
WHALE_TELEGRAM_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION=whale_session

# ==================================================
# ETHERSCAN [OPTIONAL — Phase 2 ETH wallet tracking]
# ==================================================
ETHERSCAN_API_KEY=

# ==================================================
# EMAIL ALERTS [OPTIONAL]
# ==================================================
EMAIL_USERNAME=
EMAIL_PASSWORD=

# ==================================================
# DATABASE — PostgreSQL [REQUIRED]
# ==================================================
DATABASE_URL=postgresql://user:password@localhost:5432/trading_bot
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_bot
DB_USER=user
DB_PASSWORD=password

# ==================================================
# REDIS [OPTIONAL — enables pub/sub, live dashboard]
# ==================================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================================================
# TRADING DEFAULTS
# ==================================================

# Starting paper balance
DEFAULT_BALANCE=10000

# Risk per trade (% of balance)
DEFAULT_RISK=0.75
CRYPTO_RISK_PER_TRADE=0.35
MAX_RISK_PER_TRADE=2.0

# Maximum concurrent positions
MAX_POSITIONS=5

# Per-category position caps
CAP_FOREX=3
CAP_CRYPTO=3
CAP_COMMODITIES=2
CAP_INDICES=2

# ==================================================
# SIGNAL QUALITY
# ==================================================

MIN_CONFIDENCE_SCORE=0.70
MIN_FINAL_CONFIDENCE=0.55
ALERT_THRESHOLD=0.75
CRYPTO_ALERT_THRESHOLD=0.80

# ==================================================
# ML SETTINGS
# ==================================================

ML_MODEL_TYPE=ensemble
TRAIN_TEST_SPLIT=0.8
MODEL_MAX_AGE_HOURS=24

# ==================================================
# DATA / ANALYSIS
# ==================================================

TIMEFRAMES=1d,1h,15m
LOOKBACK_PERIOD=100
PREDICTION_HORIZON=5
CACHE_TTL=300

# ==================================================
# SYSTEM
# ==================================================

LOG_LEVEL=INFO
SCAN_INTERVAL_SECONDS=45
MAX_SCAN_WORKERS=8
WS_RECONNECT_DELAY=30
WS_MAX_RECONNECT_DELAY=120
