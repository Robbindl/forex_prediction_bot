# Execution broker profile switching
EXECUTION_MODE=ig_demo
EXECUTION_ROLE=trader
BROKER_EXECUTION_PROVIDER=ig
BROKER_EXECUTION_STATE_PATH=data/runtime_locks/execution_broker_state.json

# IG execution profile
IG_EXECUTION_ENABLED=true
IG_EXECUTION_DRY_RUN=false
IG_EXECUTION_CURRENCY=USD
IG_EXECUTION_ROUTE_CATEGORIES=
IG_EXECUTION_ROUTE_ASSETS=
IG_EXECUTION_DISABLED_ASSETS=XRP-USD
IG_STARTUP_TRADE_FREEZE_SECONDS=300
IG_MIN_SECONDS_BETWEEN_ENTRIES=300
IG_MAX_NEW_TRADES_PER_CYCLE=1
IG_MIN_EXECUTION_CONFIDENCE=0.64
IG_MIN_EXECUTION_OPPORTUNITY_SCORE=0.60
IG_MIN_EXECUTION_SETUP_QUALITY=0.50
IG_MIN_EXECUTION_ALIGNMENT=0.50
IG_MAX_EXECUTION_CONFLICTS=0
IG_MAX_OPEN_POSITIONS=3
IG_MAX_OPEN_POSITIONS_PER_CATEGORY=1
IG_MAX_SAME_DIRECTION_POSITIONS=2
IG_MIN_ATTACHED_ORDER_RR=1.0
IG_MANAGED_TRAILING_STOP_ENABLED=true
IG_TRAILING_STOP_MIN_UPDATE_SECONDS=60
IG_TRAILING_STOP_MIN_IMPROVEMENT_R=0.10
IG_PORTFOLIO_EMERGENCY_FLATTEN_ENABLED=true
IG_PORTFOLIO_MAX_FLOATING_LOSS_PCT=1.5
IG_PORTFOLIO_MIN_LOSING_POSITIONS=3
IG_PORTFOLIO_COOLDOWN_MINUTES=60
IG_DAILY_GUARD_ENABLED=true
IG_DAILY_MAX_LOSS_PCT=2.0
IG_DAILY_PROFIT_TARGET_PCT=3.0
IG_DAILY_GUARD_FLATTEN_ON_PROFIT_TARGET=true
IG_DAILY_GUARD_TIMEZONE=Africa/Nairobi

# cTrader execution profile
# Recommended for small-account execution: Pepperstone cTrader.
# Keep IC Markets cTrader for depth unless you explicitly switch it to execution.
CTRADER_EXECUTION_ENABLED=false
CTRADER_EXECUTION_DRY_RUN=true
CTRADER_EXECUTION_BROKER_NAME=pepperstone
CTRADER_EXECUTION_ENVIRONMENT=demo
CTRADER_EXECUTION_ACCOUNT_ID=
CTRADER_EXECUTION_CLIENT_ID=
CTRADER_EXECUTION_CLIENT_SECRET=
CTRADER_EXECUTION_ACCESS_TOKEN=
CTRADER_EXECUTION_REFRESH_TOKEN=
CTRADER_EXECUTION_REDIRECT_URI=http://localhost
CTRADER_EXECUTION_TOKEN_CACHE_PATH=data/runtime_locks/ctrader_execution_tokens.json

# Optional broker-specific cTrader execution credentials. If these are set,
# they override the generic CTRADER_EXECUTION_* values for that broker.
PEPPERSTONE_CTRADER_EXECUTION_ENABLED=false
PEPPERSTONE_CTRADER_EXECUTION_DRY_RUN=true
PEPPERSTONE_CTRADER_EXECUTION_ACCOUNT_ID=
PEPPERSTONE_CTRADER_EXECUTION_CLIENT_ID=
PEPPERSTONE_CTRADER_EXECUTION_CLIENT_SECRET=
PEPPERSTONE_CTRADER_EXECUTION_ACCESS_TOKEN=
PEPPERSTONE_CTRADER_EXECUTION_REFRESH_TOKEN=
PEPPERSTONE_CTRADER_EXECUTION_ROUTE_CATEGORIES=forex,crypto,commodities
PEPPERSTONE_CTRADER_EXECUTION_ROUTE_ASSETS=
PEPPERSTONE_CTRADER_EXECUTION_DISABLED_ASSETS=
PEPPERSTONE_CTRADER_EXECUTION_ALLOWED_CATEGORIES=forex,crypto,commodities,indices
ICMARKETS_CTRADER_EXECUTION_ENABLED=false
ICMARKETS_CTRADER_EXECUTION_DRY_RUN=true
ICMARKETS_CTRADER_EXECUTION_ACCOUNT_ID=
ICMARKETS_CTRADER_EXECUTION_CLIENT_ID=
ICMARKETS_CTRADER_EXECUTION_CLIENT_SECRET=
ICMARKETS_CTRADER_EXECUTION_ACCESS_TOKEN=
ICMARKETS_CTRADER_EXECUTION_REFRESH_TOKEN=
ICMARKETS_CTRADER_EXECUTION_ROUTE_CATEGORIES=forex,commodities
ICMARKETS_CTRADER_EXECUTION_ROUTE_ASSETS=
ICMARKETS_CTRADER_EXECUTION_DISABLED_ASSETS=BTC-USD,ETH-USD,BNB-USD,SOL-USD,XRP-USD
ICMARKETS_CTRADER_EXECUTION_ALLOWED_CATEGORIES=forex,commodities,indices

CTRADER_EXECUTION_ROUTE_CATEGORIES=forex,crypto,commodities
CTRADER_EXECUTION_ROUTE_ASSETS=
CTRADER_EXECUTION_DISABLED_ASSETS=
CTRADER_EXECUTION_ALLOWED_CATEGORIES=forex,crypto,commodities,indices
CTRADER_STARTUP_TRADE_FREEZE_SECONDS=180
CTRADER_MIN_SECONDS_BETWEEN_ENTRIES=300
CTRADER_MAX_NEW_TRADES_PER_CYCLE=1
CTRADER_MIN_EXECUTION_CONFIDENCE=0.70
CTRADER_MIN_EXECUTION_OPPORTUNITY_SCORE=0.56
CTRADER_MIN_EXECUTION_SETUP_QUALITY=0.50
CTRADER_MIN_EXECUTION_ALIGNMENT=0.50
CTRADER_MIN_FINAL_TP_RR=1.0
CTRADER_MAX_EXECUTION_CONFLICTS=0
CTRADER_MAX_OPEN_POSITIONS=3
CTRADER_MAX_OPEN_POSITIONS_PER_CATEGORY=2
CTRADER_MAX_SAME_DIRECTION_POSITIONS=2
CTRADER_MANAGED_TRAILING_STOP_ENABLED=true
CTRADER_TRAILING_STOP_MIN_UPDATE_SECONDS=45
CTRADER_TRAILING_STOP_MIN_IMPROVEMENT_R=0.05
CTRADER_PORTFOLIO_EMERGENCY_FLATTEN_ENABLED=true
CTRADER_PORTFOLIO_MAX_FLOATING_LOSS_PCT=1.5
CTRADER_PORTFOLIO_MIN_LOSING_POSITIONS=3
CTRADER_PORTFOLIO_COOLDOWN_MINUTES=60
CTRADER_DAILY_GUARD_ENABLED=true
CTRADER_DAILY_MAX_LOSS_PCT=2.0
CTRADER_DAILY_PROFIT_TARGET_PCT=3.0
CTRADER_DAILY_GUARD_FLATTEN_ON_PROFIT_TARGET=true
CTRADER_DAILY_GUARD_TIMEZONE=Africa/Nairobi
