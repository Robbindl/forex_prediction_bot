{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Full Analysis",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["main_bot.py", "--full-analysis"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Full Analysis (1h)",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["main_bot.py", "--full-analysis", "--interval", "1h"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Watch EUR/USD",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["main_bot.py", "--watch", "EUR/USD", "--type", "forex"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Install Requirements",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "pip", "install", "-r", "requirements.txt"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Update Requirements",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "pip", "install", "--upgrade", "-r", "requirements.txt"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        }
    ]
}
