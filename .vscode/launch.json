P{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Full Analysis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main_bot.py",
            "console": "integratedTerminal",
            "args": ["--full-analysis"],
            "justMyCode": true
        },
        {
            "name": "Full Analysis (1h interval)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main_bot.py",
            "console": "integratedTerminal",
            "args": ["--full-analysis", "--interval", "1h"],
            "justMyCode": true
        },
        {
            "name": "Watch EUR/USD",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main_bot.py",
            "console": "integratedTerminal",
            "args": ["--watch", "EUR/USD", "--type", "forex", "--interval", "15m"],
            "justMyCode": true
        },
        {
            "name": "Watch AAPL",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main_bot.py",
            "console": "integratedTerminal",
            "args": ["--watch", "AAPL", "--type", "stock"],
            "justMyCode": true
        },
        {
            "name": "Quick Analysis (No Training)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main_bot.py",
            "console": "integratedTerminal",
            "args": ["--full-analysis", "--no-train"],
            "justMyCode": true
        },
        {
            "name": "Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
